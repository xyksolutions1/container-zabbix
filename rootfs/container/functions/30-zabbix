${sso_settings}
EOF
}

write_config_value() {
    local config_file="${1}"
    local env_var_name="${2}"
    local config_key="${3}"
    local lowercase_flag="${4}"

    if [ -n "${!env_var_name}" ]; then
        local val="${!env_var_name}"
        if [ "${lowercase_flag}" = "lowercase" ] ; then
            val="$(printf '%s' "${val}" | tr '[:upper:]' '[:lower:]')"
        fi
        echo "${config_key}=${val}" | write_file -a "${config_file}"
    fi
}
